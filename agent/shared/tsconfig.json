{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "../..",
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
