# Agent wallet (delegate keypair, base58-encoded private key)
SOLANA_PRIVATE_KEY=

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Vault configuration
VAULT_TOKEN_MINT=           # underlying token mint (USDC)
VAULT_ID=0                  # which vault
STRATEGY_ID=0               # which strategy this agent manages

# Mock Kamino program (configured via Anchor.toml constants)
KAMINO_PROGRAM_ID=H4tUCeXMQduSmB6fjqbYMdFb49E8YnEHku5NWFrWKaGU

# Mock Jupiter program (currently not used in MVP, but reserved)
JUPITER_PROGRAM_ID=43FrWWHc13Fp4rsnb3XjDV5dfmWWoyLNzdSe1pqkLxn7

# Asset mints (devnet test mints)
USDC_MINT=
BTC_MINT=
SOL_MINT=

# Strategy parameters
EVAL_INTERVAL_MS=300000     # 5 minutes
MAX_LEVERAGE=3.0
TARGET_LEVERAGE_MIN=2.0
TARGET_LEVERAGE_MAX=2.5
MIN_LOOP_NET_APY_PCT=1.5
HF_COMFORTABLE=1.8
HF_WARNING=1.3

# Dry-run mode (true = log decisions but don't send transactions)
DRY_RUN=false
