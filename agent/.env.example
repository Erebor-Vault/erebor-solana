# Agent wallet (delegate keypair, base58-encoded private key)
SOLANA_PRIVATE_KEY=

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# Vault configuration
VAULT_TOKEN_MINT=           # underlying token mint address (e.g., USDC)
VAULT_ID=0                  # which vault (multiple vaults per token)
STRATEGY_ID=0               # which strategy this agent manages

# Protocol configuration (mock_lulo on devnet, real Lulo on mainnet)
LULO_PROGRAM_ID=            # target protocol program ID
LULO_TREASURY=              # protocol's treasury token account PDA

# Agent configuration
POLL_INTERVAL_MS=30000      # how often to check for balance changes (30 seconds)
MIN_LEND_AMOUNT=1000000     # minimum amount to trigger lending (1 USDC with 6 decimals)
