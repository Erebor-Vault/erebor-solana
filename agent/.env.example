# Agent wallet (delegate keypair).
# Either base58-encoded secret key OR a JSON byte array (matches `solana-keygen`).
SOLANA_PRIVATE_KEY=

# Solana RPC endpoint
RPC_URL=https://api.devnet.solana.com

# Optional. When set, the agent uses Claude (Anthropic) for the decision step
# and falls back to the rule-based advisor between calls / on errors.
# Leave blank to run purely on the deterministic rule-based advisor.
ANTHROPIC_API_KEY=

# Vault configuration
PROGRAM_ID=DXcUni7VCBiLA8MEa2cB4nektLT33Dth62skuiyuwm5B
VAULT_TOKEN_MINT=           # underlying token mint address (e.g., USDC)
VAULT_ID=0                  # which vault on (token_mint, vault_id) to read
STRATEGY_ID=0               # which strategy this agent manages

# Agent cadence
POLL_INTERVAL_MS=30000      # how often to check on-chain state (default 30s)
LLM_COOLDOWN_SECONDS=300    # min seconds between Claude calls when state unchanged
MIN_LEND_AMOUNT=1000000     # minimum amount to trigger lending (1 USDC w/ 6 dp)

# Lending integration
USE_MOCK_LULO=true          # true on devnet/localnet — strategy.lend / .withdraw stay mocked
